# -----------------------------------------------------------------------------
# Template only — copy to .env.local and fill in. Do not put real secrets here.
#   cp .env.example .env.local
# -----------------------------------------------------------------------------

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic --------------------------------------------------------------
ANTHROPIC_API_KEY=

# --- Encryption (openssl rand -base64 32) ----------------------------------
ENCRYPTION_KEY=

# --- Vapi ------------------------------------------------------------------
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_WEBHOOK_URL=
# E.164 staff line if workspace has no human_redirect_number (e.g. +14155552671)
VAPI_FALLBACK_E164=

# --- Google OAuth ----------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional if NEXT_PUBLIC_APP_URL is set (callback = NEXT_PUBLIC_APP_URL + /api/google/oauth/callback)
GOOGLE_OAUTH_REDIRECT_URI=

# --- GCP Cloud Tasks / worker ----------------------------------------------
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_JSON=
CLOUD_TASKS_QUEUE_NAME=zol-agent-queue
WORKER_URL=

# --- App URL ---------------------------------------------------------------
# Must match your deployed host so auth emails + OAuth callbacks resolve correctly.
# Production: https://zol-v1.vercel.app
# Local dev:  http://localhost:3000
NEXT_PUBLIC_APP_URL=
