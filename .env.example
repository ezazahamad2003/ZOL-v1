# -----------------------------------------------------------------------------
# Template only — copy to .env.local and fill in. Do not put real secrets here.
#   cp .env.example .env.local
#
# URLs you only know AFTER first Vercel deploy:
#   • Production host: https://YOUR_PROJECT.vercel.app (shown on deployment)
#   • Then set in Vercel Environment Variables (and Google OAuth console):
#       NEXT_PUBLIC_APP_URL=https://YOUR_PROJECT.vercel.app
#       GOOGLE_OAUTH_REDIRECT_URI=https://YOUR_PROJECT.vercel.app/api/google/oauth/callback
#       VAPI_WEBHOOK_URL=https://YOUR_PROJECT.vercel.app/api/vapi/webhook
#   Local dev keeps localhost values in .env.local only.
# -----------------------------------------------------------------------------

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI -----------------------------------------------------------------
OPENAI_API_KEY=

# --- Encryption (openssl rand -base64 32) ----------------------------------
ENCRYPTION_KEY=

# --- Vapi ------------------------------------------------------------------
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_WEBHOOK_URL=

# --- Google OAuth ----------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback

# --- GCP Cloud Tasks / worker ----------------------------------------------
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_JSON=
CLOUD_TASKS_QUEUE_NAME=zol-agent-queue
WORKER_URL=

# --- App URL ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
